{
  "$schema": "https://developer.microsoft.com/json-schemas/api-extractor/v7/api-extractor.schema.json",
  "projectFolder": "..",
  "mainEntryPointFilePath": "<projectFolder>/dist/analyze/index.d.ts",
  "apiReport": {
    "enabled": true,
    "reportFolder": "<projectFolder>/api-report",
    "reportFileName": "sh-ast-analyze.api.md"
  },
  "docModel": {
    "enabled": true,
    "apiJsonFilePath": "<projectFolder>/temp/sh-ast-analyze.api.json"
  },
  "dtsRollup": {
    "enabled": true,
    "untrimmedFilePath": "<projectFolder>/dist/analyze.d.ts"
  },
  "tsdocMetadata": {
    "enabled": false
  }
}
